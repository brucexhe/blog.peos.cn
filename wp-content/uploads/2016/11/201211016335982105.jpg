<script type="text/javascript" src="/statics/v3/js/global.js"></script>
<script>
function countDown(secs){ 
 tiao.innerHTML=secs; 
 if(--secs>0){ 
  setTimeout("countDown("+secs+")",1000); 
  }else{
	location.href="http://www.xp510.com/";
  }
} 
 countDown(3); 
</script>
